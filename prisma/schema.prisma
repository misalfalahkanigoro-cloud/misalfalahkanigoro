  is_active     Boolean?          @default(true)
  created_at    DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?         @default(now()) @db.Timestamptz(6)
  library_media library_media[]

  @@index([is_active, display_order], map: "idx_library_media_types_active_order")
}

model library_media {
  id                  Int                @id @default(autoincrement())
  title               String
  description         String?
  category_id         Int
  media_type_id       Int
  level_id            Int
  visibility          library_visibility @default(PUBLIC)
  is_featured         Boolean?           @default(false)
  is_active           Boolean?           @default(true)
  file_name           String?
  file_mime_type      String?
  file_extension      String?
  file_size_bytes     BigInt?
  storage_provider    String?            @default("r2")
  storage_bucket      String?
  storage_path        String?
  file_url            String
  thumbnail_provider  String?            @default("r2")
  thumbnail_bucket    String?
  thumbnail_path      String?
  thumbnail_url       String?
  source_url          String?
  source_label        String?
  tags                Json?              @default("[]")
  metadata            Json?              @default("{}")
  view_count          Int?               @default(0)
  download_count      Int?               @default(0)
  published_at        DateTime?          @default(now()) @db.Timestamptz(6)
  created_at          DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?          @default(now()) @db.Timestamptz(6)
  library_categories  library_categories @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  library_media_types library_media_types @relation(fields: [media_type_id], references: [id], onUpdate: NoAction)
  library_levels      library_levels     @relation(fields: [level_id], references: [id], onUpdate: NoAction)

  @@index([visibility, is_active, published_at], map: "idx_library_media_visibility_active")
  @@index([category_id], map: "idx_library_media_category")
  @@index([media_type_id], map: "idx_library_media_type")
  @@index([level_id], map: "idx_library_media_level")
  @@index([storage_bucket, storage_path], map: "idx_library_media_storage")
  @@index([is_featured], map: "idx_library_media_featured")
}

